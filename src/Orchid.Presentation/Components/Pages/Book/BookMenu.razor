@using MudBlazor.Services
@using Orchid.Core.Models
@using Orchid.Core.Models.ValueObjects
@inject IBrowserViewportService BrowserViewportService
@implements IAsyncDisposable

@if (Book != null)
{
    <MudDrawer @bind-Open="DrawerOpen" Anchor="Anchor.Top" Elevation="2"
               Variant="DrawerVariant.Temporary" Height="@_dynamicDrawerHeight">
        <div class="d-flex align-center w-100 @_dynamicPadding"
             style="background-color: var(--mud-palette-background-grey); overflow: hidden; min-height: @_dynamicDrawerHeight; box-sizing: border-box;">

            @if (_isMobile)
            {
                <div class="d-flex flex-column flex-grow-1 overflow-hidden" style="gap: 2px; min-width: 0;">
                    <div class="d-flex align-center" style="min-width: 0;">
                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small"
                                 Class="flex-shrink-0 mud-text-secondary"
                                 Style="margin-right: 6px; font-size: 0.9rem;"/>
                        <MudText Class="text-truncate" Style="@_dynamicTitleStyle">
                            @Book.Title.Value
                        </MudText>
                    </div>

                    @if (Book.Authors.Any())
                    {
                        <MudText Class="text-truncate mud-text-secondary"
                                 Style="@_dynamicSubtitleIndentedStyle">
                            @string.Join(", ", Book.Authors.Select(a => a.Name))
                        </MudText>
                    }

                    <div class="d-flex align-center" style="min-width: 0; padding-left: 22px;">
                        <MudIcon Icon="@Icons.Material.Filled.BookmarkBorder" Size="Size.Small"
                                 Class="flex-shrink-0 mud-text-secondary"
                                 Style="margin-right: 6px; font-size: 0.75rem;"/>
                        <MudText Class="text-truncate mud-text-secondary" Style="@_dynamicSubtitleStyle">
                            Chapter: @CurrentChapterTitle
                            <span style="margin: 0 4px; opacity: 0.4;">·</span>
                            Page: @(CurrentChapterPageIndex.HasValue ? CurrentChapterPageIndex.Value + 1 : "–") / @(CurrentChapterTotalPages?.ToString() ?? "–")
                            <span style="margin: 0 4px; opacity: 0.4;">·</span>
                            Total: @TotalBookPages
                        </MudText>
                    </div>
                </div>

                <MudIconButton Icon="@Icons.Material.Filled.FormatListBulleted"
                               OnClick="OnNavigationClick"
                               Color="Color.Default"
                               Size="Size.Small"
                               Class="flex-shrink-0 mud-text-secondary"
                               Style="padding: 6px; margin-left: 4px;"/>
            }
            else
            {
                <div class="d-flex align-center flex-grow-1 overflow-hidden" style="gap: 8px; min-width: 0;">

                    <div class="d-flex align-center flex-shrink-1 overflow-hidden" style="gap: 6px; min-width: 0;">
                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small"
                                 Class="flex-shrink-0 mud-text-secondary"/>
                        <MudText Class="text-truncate" Style="@_dynamicTitleStyle">
                            @Book.Title.Value
                        </MudText>
                        @if (Book.Authors.Any())
                        {
                            <MudText Class="text-truncate mud-text-secondary flex-shrink-1"
                                     Style="@_dynamicSubtitleMarginStyle">
                                — @string.Join(", ", Book.Authors.Select(a => a.Name))
                            </MudText>
                        }
                    </div>

                    <MudDivider Vertical="true" FlexItem="true" Style="opacity: 0.3; margin: 8px 4px;"/>

                    <div class="d-flex align-center flex-shrink-0" style="gap: 6px;">
                        <MudIcon Icon="@Icons.Material.Filled.BookmarkBorder" Size="Size.Small"
                                 Class="flex-shrink-0 mud-text-secondary"/>
                        <MudText Class="mud-text-secondary" Style="@($"{_dynamicSubtitleStyle} white-space: nowrap;")">
                            Chapter: @CurrentChapterTitle
                            <span style="margin: 0 6px; opacity: 0.35;">|</span>
                            Page: @(CurrentChapterPageIndex.HasValue ? CurrentChapterPageIndex.Value + 1 : "–") / @(CurrentChapterTotalPages?.ToString() ?? "–")
                            <span style="margin: 0 6px; opacity: 0.35;">|</span>
                            Total: @TotalBookPages
                        </MudText>
                    </div>
                </div>

                <MudButton StartIcon="@Icons.Material.Filled.FormatListBulleted"
                           OnClick="OnNavigationClick"
                           Color="Color.Default"
                           Size="Size.Small"
                           Class="flex-shrink-0 mud-text-secondary"
                           Style="@($"text-transform: none; font-size: {_dynamicButtonFontSize}; border-radius: 8px; padding: 4px 12px;")">
                    Navigation
                </MudButton>
            }

        </div>
    </MudDrawer>
}

@code {
    [Parameter] public Book? Book { get; set; }
    [Parameter] public Cover? Cover { get; set; }

    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    [Parameter] public string CurrentChapterTitle { get; set; } = string.Empty;
    [Parameter] public int TotalBookPages { get; set; }
    [Parameter] public int? CurrentChapterPageIndex { get; set; }
    [Parameter] public int? CurrentChapterTotalPages { get; set; }
    [Parameter] public EventCallback OnNavigationClick { get; set; }

    private bool DrawerOpen
    {
        get => Open;
        set
        {
            if (Open != value)
                OpenChanged.InvokeAsync(value);
        }
    }

    private bool _isMobile = true;
    private string _dynamicDrawerHeight = "68px";
    private string _dynamicPadding = "px-3";
    private string _dynamicTitleStyle = "font-size: 0.78rem; font-weight: 600; line-height: 1.2; color: var(--mud-palette-text-primary);";
    private string _dynamicSubtitleStyle = "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary);";
    private string _dynamicSubtitleIndentedStyle = "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary); padding-left: 22px;";
    private string _dynamicSubtitleMarginStyle = "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary); margin-left: 4px;";
    private string _dynamicButtonFontSize = "0.82rem";

    private readonly Guid _breakpointSubscriptionId = Guid.NewGuid();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var breakpoint = await BrowserViewportService.GetCurrentBreakpointAsync();
            UpdateDynamicStyles(breakpoint);

            await BrowserViewportService.SubscribeAsync(
                _breakpointSubscriptionId,
                e => InvokeAsync(() => UpdateDynamicStyles(e.Breakpoint)),
                new ResizeOptions { ReportRate = 100 }
            );
        }
    }

    private void UpdateDynamicStyles(Breakpoint breakpoint)
    {
        var isMobile = breakpoint < Breakpoint.Md;

        var newHeight = isMobile ? "68px" : "52px";
        var newPadding = isMobile ? "px-3" : "px-5";

        var newTitleStyle = isMobile
            ? "font-size: 0.78rem; font-weight: 600; line-height: 1.2; color: var(--mud-palette-text-primary);"
            : "font-size: 0.92rem; font-weight: 600; line-height: 1; color: var(--mud-palette-text-primary);";

        var newSubtitleStyle = isMobile
            ? "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary);"
            : "font-size: 0.82rem; line-height: 1; color: var(--mud-palette-text-secondary);";

        var newSubtitleIndentedStyle = isMobile
            ? "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary); padding-left: 22px;"
            : "font-size: 0.82rem; line-height: 1; color: var(--mud-palette-text-secondary); padding-left: 22px;";

        var newSubtitleMarginStyle = isMobile
            ? "font-size: 0.65rem; line-height: 1.2; color: var(--mud-palette-text-secondary); margin-left: 4px;"
            : "font-size: 0.82rem; line-height: 1; color: var(--mud-palette-text-secondary); margin-left: 4px;";

        var newButtonFontSize = isMobile ? "0.7rem" : "0.82rem";

        if (_isMobile != isMobile || _dynamicDrawerHeight != newHeight)
        {
            _isMobile = isMobile;
            _dynamicDrawerHeight = newHeight;
            _dynamicPadding = newPadding;
            _dynamicTitleStyle = newTitleStyle;
            _dynamicSubtitleStyle = newSubtitleStyle;
            _dynamicSubtitleIndentedStyle = newSubtitleIndentedStyle;
            _dynamicSubtitleMarginStyle = newSubtitleMarginStyle;
            _dynamicButtonFontSize = newButtonFontSize;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_breakpointSubscriptionId != Guid.Empty)
            await BrowserViewportService.UnsubscribeAsync(_breakpointSubscriptionId);
    }
}
