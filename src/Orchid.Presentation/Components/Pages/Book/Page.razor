@page "/book"
@using System.Collections.Concurrent
@using Orchid.Application.Common.Services
@using Orchid.Application.Models
@using Orchid.Core.Models
@using Orchid.Core.Models.ValueObjects
@using Orchid.Presentation.Models
@using Orchid.Presentation.Services
@inject IBookResourcesService BookResourcesService
@inject BookPaginationService BookPaginationService
@inject IPaginationCacheService PaginationCacheService
@inject NavigationManager NavManager
@inject IJSRuntime Js
@inject IDialogService DialogService
@inject ICloudSyncService CloudSyncService
@inject IEnumerable<ICloudStorageProvider> CloudProviders
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<BookMenu
    @bind-Open="_drawerOpen"
    Book="@_currentBook"
    Cover="@_currentBookCover"
    CurrentChapterTitle="@_chapterTitles.ElementAtOrDefault(_currentPageIdentifier.ChapterIndex)"
    TotalBookPages="@_chapterPageCounts.Values.Sum()"
    CurrentChapterPageIndex="@(_reader?.CurrentPageIndex)"
    CurrentChapterTotalPages="@(_reader?.CurrentTotalPages)"
    OnNavigationClick="OpenNavigation"
/>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0" Style="height: 100%; display: flex; flex-direction: column;">
    <LoadingOverlay IsVisible="_isBookLoading" Text="Loading book..."/>

    @if (_currentBook != null)
    {
        <FloatingInfoButton OnClick="ToggleDrawer"/>

        <Reader @ref="_reader"
                BookId="@_currentBook.Id"
                ChaptersCount="@_chaptersCount"
                PaginationStore="@_paginationStore"
                Css="@_css"
                OnPageChanged="UpdateCurrentPageIdentifier"
                OnPageContextChangeCallback="OnPageContextChange"
                OnPageContextChangeEndCallback="OnPageContextChangeEnd"/>
    }
</MudContainer>

@code {

    [SupplyParameterFromQuery(Name = "path")]
    public string? FilePath { get; set; }

    private Reader? _reader;
    private Book? _currentBook;
    private Cover? _currentBookCover;
    private IEnumerable<CssFile> _css = [];

    private int _chaptersCount;
    private List<string> _chapterTitles = [];

    private ChapterPaginationStore _paginationStore = null!;
    private readonly ConcurrentDictionary<int, int> _chapterPageCounts = new();

    private PageIdentifier _currentPageIdentifier = PageIdentifier.Empty;
    private bool _isBookLoading;
    private bool _drawerOpen;

    private CancellationTokenSource? _syncCts;

    protected override async Task OnInitializedAsync()
    {
        _paginationStore = new ChapterPaginationStore(PaginationCacheService);

        if (!string.IsNullOrEmpty(FilePath))
            await ReadBook(System.Net.WebUtility.UrlDecode(FilePath));
        else
            NavManager.NavigateTo("/");
    }

    private async Task ReadBook(string path)
    {
        _isBookLoading = true;
        StateHasChanged();

        try
        {
            _currentBook = await BookResourcesService.ReadBookAsync(path);
            _css = await BookResourcesService.GetBookCssFilesAsync(path);
            var chapters = await BookResourcesService.ReadChaptersAsync(path, _currentBook.Id);

            _chaptersCount = chapters.Count;
            _chapterTitles = chapters.Select(c => c.Title).ToList();
            _currentBookCover = _currentBook.Cover ?? await DefaultCover();

            StateHasChanged();
            await Task.Delay(50);

            StartPagesCalculation(chapters);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            NavManager.NavigateTo("/");
        }
    }

    private async Task<Cover> DefaultCover()
    {
        await using var stream = await FileSystem.OpenAppPackageFileAsync("wwwroot/images/no_cover_image.png");
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return Cover.Create("no_cover_image.png", "images/no_cover_image.png", ms.ToArray())!;
    }

    private async Task OnPageContextChange()
    {
        _isBookLoading = true;
        _chapterPageCounts.Clear();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnPageContextChangeEnd()
    {
        var chapters = await BookResourcesService.ReadChaptersAsync(System.Net.WebUtility.UrlDecode(FilePath)!, _currentBook!.Id);
        StartPagesCalculation(chapters);
    }

    private void StartPagesCalculation(List<Chapter> chapters)
    {
        BookPaginationService.StartBackgroundPageCalculation(
            _currentBook!.Id, chapters, _reader!.PaginationSandbox, _paginationStore,
            async (idx, pagesCount) =>
            {
                _chapterPageCounts[idx] = pagesCount;
                var currentIdx = _currentPageIdentifier.ChapterIndex;
                // Update for prev, next and current chapter to ensure that all pages are in place
                if (idx == currentIdx || idx == currentIdx + 1 || idx == currentIdx - 1)
                {
                    await InvokeAsync(() => _reader.UpdateAsync());
                }
            },
            async () =>
            {
                _currentPageIdentifier = await ResolveInitialPositionAsync(_currentPageIdentifier);

                _isBookLoading = false;
                await InvokeAsync(async () =>
                {
                    await _reader.RestorePositionAsync(_currentPageIdentifier);
                    StateHasChanged();
                });
            },
            jsRuntime: Js
        );
    }

    private async Task<PageIdentifier> ResolveInitialPositionAsync(PageIdentifier localPosition)
    {
        var provider = CloudProviders.FirstOrDefault(p => p.IsAuthenticated);
        if (provider == null || _currentBook == null)
            return localPosition;

        // Force fallback to local position if network is slow/unreachable to prevent UI hanging
        using var timeoutCts = new CancellationTokenSource(TimeSpan.FromSeconds(5));

        try
        {
            var initialProgress = new ReadingProgress(_currentBook.Id, localPosition, DateTimeOffset.MinValue);
            var result = await CloudSyncService.TrySyncProgressAsync(provider.ProviderId, initialProgress, timeoutCts.Token);

            if (result is { State: SyncState.Downloaded, ResolvedProgress: not null })
            {
                Snackbar.Add("Progress is restored from cloud", Severity.Success);
                return result.ResolvedProgress.Position;
            }
        }
        catch (OperationCanceledException)
        {
            Snackbar.Add("Cloud is not responding. Retrieve data from local.", Severity.Warning);
        }

        return localPosition;
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task OpenNavigation()
    {
        if (_currentBook?.Navigation == null) return;

        var parameters = new DialogParameters<NavigationModal>
        {
            { x => x.Navigation, _currentBook.Navigation },
            { x => x.ChapterPageCounts, _chapterPageCounts },
            { x => x.CurrentChapterIndex, _currentPageIdentifier.ChapterIndex }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true,
            Position = DialogPosition.Center
        };

        var dialog = await DialogService.ShowAsync<NavigationModal>("", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled && result.Data is int chapterIndex)
        {
            _drawerOpen = false;

            // Empty locator opens the first page of the chapter
            var newPosition = PageIdentifier.Create(chapterIndex, string.Empty);
            _currentPageIdentifier = newPosition;

            if (_reader != null)
            {
                _isBookLoading = true;
                StateHasChanged();

                await _reader.RestorePositionAsync(newPosition);

                _isBookLoading = false;
                StateHasChanged();

                TriggerCloudSyncDebounced(newPosition);
            }
        }
    }

    private void UpdateCurrentPageIdentifier(PageIdentifier identifier)
    {
        _currentPageIdentifier = identifier;
        TriggerCloudSyncDebounced(identifier);
    }

    private void TriggerCloudSyncDebounced(PageIdentifier position)
    {
        _syncCts?.Cancel();
        _syncCts = new CancellationTokenSource();
        var token = _syncCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(3000, token);

                if (!token.IsCancellationRequested && _currentBook != null)
                {
                    var progress = new ReadingProgress(_currentBook.Id, position, DateTimeOffset.UtcNow);
                    await PerformCloudSyncAsync(progress, token);
                }
            }
            catch (TaskCanceledException)
            {
            }
        }, token);
    }

    private async Task PerformCloudSyncAsync(ReadingProgress localProgress, CancellationToken token)
    {
        var provider = CloudProviders.FirstOrDefault(p => p.IsAuthenticated);
        if (provider == null) return;

        var result = await CloudSyncService.TrySyncProgressAsync(provider.ProviderId, localProgress, token);

        if (result is { State: SyncState.Downloaded, ResolvedProgress: not null })
        {
            await InvokeAsync(async () =>
            {
                _currentPageIdentifier = result.ResolvedProgress.Position;
                if (_reader != null)
                {
                    await _reader.RestorePositionAsync(_currentPageIdentifier);
                }

                Snackbar.Add("Progress updated.", Severity.Info);
                StateHasChanged();
            });
        }
        else if (result is { State: SyncState.Uploaded, ResolvedProgress: not null })
        {
            Snackbar.Add("Progress uploaded to the cloud.", Severity.Info);
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        _syncCts?.Cancel();
        _syncCts?.Dispose();

        BookPaginationService.StopCalculation();
        try
        {
            if (_reader?.PaginationSandbox.Context != null)
            {
                await Js.InvokeVoidAsync("utils.cleanupElementContent", _reader.PaginationSandbox);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Cleanup failed: {ex.Message}");
        }

        _paginationStore.Clear();
        _currentBook = null;

        GC.Collect(2, GCCollectionMode.Forced, true);
        GC.WaitForPendingFinalizers();
    }

}
