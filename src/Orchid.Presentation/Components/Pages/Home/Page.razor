@page "/"
@using Orchid.Application.Common.Services
@using Orchid.Application.Models
@inject ILibraryService LibraryService
@inject NavigationManager NavManager
@inject IAppSettingsService AppSettings

<style>
    .featured-card {
        transition: box-shadow 0.2s ease-in-out;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .featured-card:hover {
        box-shadow: var(--mud-elevation-6) !important;
    }

    .mobile-list-item {
        transition: background-color 0.2s ease;
        border: 1px solid var(--mud-palette-lines-default);
    }

    .mobile-list-item:active {
        background-color: var(--mud-palette-action-default-hover);
    }

    .add-book-fab {
        position: fixed !important;
        bottom: 2rem;
        right: 2rem;
        z-index: 100;
    }

    .book-cover-card {
        aspect-ratio: 2 / 3;
        position: relative;
        overflow: hidden;
        border-radius: 12px;
        box-shadow: var(--mud-elevation-2);
        cursor: pointer;
        background-color: var(--mud-palette-background-grey);
    }

    .book-cover-card:hover {
        box-shadow: var(--mud-elevation-6);
    }

    .book-cover-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .book-cover-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 100%;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
        padding: 1rem;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        opacity: 0;
        transition: opacity 0.2s ease-in-out;
    }

    .book-cover-card:hover .book-cover-overlay {
        opacity: 1;
    }
</style>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8 pb-20 hide-scrollbar" Style="height: 100%; overflow-y: auto;">
    @if (_books == null)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7 rounded"/>
    }
    else if (!_books.Any())
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="mt-16 pa-8">
            <MudIcon Icon="@Icons.Material.Filled.LibraryAdd" Style="font-size: 5rem;" Color="Color.Primary"
                     Class="mb-2 opacity-50"/>
            <MudText Typo="Typo.h5" Style="font-weight: 600;" Class="mb-1">Your library is empty</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">Open a file to start reading</MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                       OnClick="PickFile" Class="rounded-lg px-6 py-2">
                Add your first book
            </MudButton>
        </MudStack>
    }
    else
    {
        @if (_featuredBook != null)
        {
            <MudText Typo="Typo.h6" Class="mb-3 fw-bold">Continue Reading</MudText>
            <MudPaper Elevation="0" Class="pa-4 mb-8 rounded-xl mud-elevation-2 featured-card" Style="cursor: pointer;"
                      @onclick="() => OpenBook(_featuredBook.FilePath)">
                <MudStack Row Spacing="4" AlignItems="AlignItems.Center">
                    <MudImage
                        Src="@(string.IsNullOrEmpty(_featuredBook.CoverPath) ? "images/no_cover_image.png" : _featuredBook.CoverPath)"
                        Width="90" Height="135" ObjectFit="ObjectFit.Cover" Elevation="3"
                        Class="rounded-lg flex-shrink-0"/>

                    <MudStack Justify="Justify.Center" Spacing="1" Class="flex-grow-1 overflow-hidden">
                        <MudText Typo="Typo.h5" Style="font-weight: 700;"
                                 Class="text-truncate">@_featuredBook.Title</MudText>
                        <MudText Typo="Typo.subtitle1" Color="Color.Secondary"
                                 Class="text-truncate">@_featuredBook.Authors</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Tertiary" Class="mt-2 fw-bold">Last
                            opened: @_featuredBook.LastOpenedAt.ToString("g")</MudText>
                    </MudStack>

                    <MudIcon Icon="@Icons.Material.Filled.PlayCircleFilled" Color="Color.Primary" Size="Size.Large"
                             Class="mr-2 d-none d-sm-inline opacity-75"/>
                </MudStack>
            </MudPaper>
        }

        <MudText Typo="Typo.h6" Class="mb-4 fw-bold">All Books</MudText>

        @* Desktop Grid View *@
        <MudHidden Breakpoint="Breakpoint.SmAndDown">
            <MudGrid Spacing="4">
                @foreach (var book in _otherBooks)
                {
                    var coverUrl = string.IsNullOrEmpty(book.CoverPath)
                        ? "images/no_cover_image.png"
                        : book.CoverPath.Replace("\\", "/");

                    <MudItem md="3" lg="2">
                        <div class="book-cover-card" @onclick="() => OpenBook(book.FilePath)">
                            <img src="@coverUrl" class="book-cover-image" alt="@book.Title"/>

                            <div class="book-cover-overlay">
                                <MudText Typo="Typo.subtitle2" Style="font-weight: 700; color: white; line-height: 1.2;"
                                         Class="text-truncate d-block mb-1">
                                    @book.Title
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.7);"
                                         Class="text-truncate d-block">
                                    @book.Authors
                                </MudText>
                            </div>
                        </div>
                    </MudItem>
                }
            </MudGrid>
        </MudHidden>

        @* Mobile List View *@
        <MudHidden Breakpoint="Breakpoint.MdAndUp">
            <MudStack Spacing="3">
                @foreach (var book in _otherBooks)
                {
                    <MudPaper Elevation="0" Class="pa-3 rounded-lg mud-elevation-1 mobile-list-item"
                              Style="cursor: pointer;" @onclick="() => OpenBook(book.FilePath)">
                        <div class="d-flex align-center gap-4">
                            <MudImage
                                Src="@(string.IsNullOrEmpty(book.CoverPath) ? "images/no_cover_image.png" : book.CoverPath)"
                                Width="60" Height="90" ObjectFit="ObjectFit.Cover" Elevation="1"
                                Class="rounded flex-shrink-0"/>

                            <div class="d-flex flex-column overflow-hidden flex-grow-1">
                                <MudText Typo="Typo.subtitle1" Class="text-truncate"
                                         Style="font-weight: 600;">@book.Title</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary"
                                         Class="text-truncate mt-1">@book.Authors</MudText>
                            </div>

                            <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Default"
                                     Class="flex-shrink-0 opacity-50"/>
                        </div>
                    </MudPaper>
                }
            </MudStack>
        </MudHidden>

        @* Floating Action Button *@
        <div class="add-book-fab">
            @* Desktop *@
            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Label="Add Book" OnClick="PickFile"
                        Class="shadow-lg"/>
            </MudHidden>

            @* Mobile *@
            <MudHidden Breakpoint="Breakpoint.MdAndUp">
                <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="PickFile"
                        Class="shadow-lg"/>
            </MudHidden>
        </div>
    }
</MudContainer>

@code {
    private List<BookSummary>? _books;
    private BookSummary? _featuredBook;
    private List<BookSummary> _otherBooks = new();

    protected override async Task OnInitializedAsync()
    {
        var summaries = await LibraryService.GetLibraryBooksAsync();
        _books = summaries.ToList();

        if (_books.Any())
        {
            _featuredBook = _books.First();
            _otherBooks = _books.Skip(1).ToList();
        }
    }

    private async Task PickFile()
    {
        var result = await FilePicker.PickAsync();
        if (result != null)
        {
            OpenBook(result.FullPath);
        }
    }

    private void OpenBook(string filePath)
    {
        AppSettings.LastOpenedBookPath = filePath;

        var encodedPath = System.Net.WebUtility.UrlEncode(filePath);
        NavManager.NavigateTo($"/book?path={encodedPath}");
    }

}
