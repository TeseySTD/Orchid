@inherits LayoutComponentBase
@inject IAppSettingsProvider AppSettings
@inject LocalizationStateService LocalizationState
@using Microsoft.Maui.Controls
@using Orchid.Application.Common.Providers
@using Orchid.Application.Dto
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider" @bind-IsDarkMode="_isDarkMode" Theme="_theme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudPopoverProvider/>

<CascadingValue Value="LocalizationState.CurrentLanguage">
    <MudLayout Class="@(_isReady ? "app-ready" : "")">
        <CascadingValue Value="this">
            <CustomErrorBoundary>
                <Orchid.Presentation.Components.Layout.Header/>
                <MudMainContent Style="height: 100vh;">
                    @Body
                </MudMainContent>
            </CustomErrorBoundary>
        </CascadingValue>
    </MudLayout>
</CascadingValue>

@code {
    private bool _isDarkMode;
    private bool _isReady = false;
    private MudThemeProvider _mudThemeProvider = null!;

    public bool IsDarkMode => _isDarkMode;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#72002A", // --md-sys-color-primary
            Secondary = "#8D4A57", // --md-sys-color-secondary
            AppbarBackground = "#72002A",
            Background = "#FFF8F7", // --md-sys-color-background
            Surface = "#FFF8F7", // --md-sys-color-surface
            TextPrimary = "#25181A", // --md-sys-color-on-background
            TextSecondary = "#574144",
            Error = "#BA1A1A"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#FFB2BE",
            Secondary = "#FFB2BE",
            AppbarBackground = "#1C1012",
            Background = "#1C1012",
            Surface = "#1C1012",
            TextPrimary = "#F4DDDF",
            TextSecondary = "#DED1D3",
            Error = "#FFB4AB"
        }
    };

    protected override void OnInitialized()
    {
        ApplyTheme(AppSettings.Theme);

        AppSettings.OnSettingsChanged += HandleSettingsChanged;
        LocalizationState.OnLanguageChanged += HandleLanguageChanged;

        if (Application.Current != null)
        {
            Application.Current.RequestedThemeChanged += OnNativeSystemThemeChanged;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _isReady = true;
        }
    }

    private void HandleSettingsChanged()
    {
        ApplyTheme(AppSettings.Theme);
        InvokeAsync(StateHasChanged);
    }
    
    private void HandleLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void ApplyTheme(AppThemeMode themeMode)
    {
        _isDarkMode = themeMode switch
        {
            AppThemeMode.Dark => true,
            AppThemeMode.Light => false,
            AppThemeMode.System => Application.Current?.RequestedTheme == AppTheme.Dark,
            _ => throw new ArgumentOutOfRangeException(nameof(themeMode), themeMode, null)
        };
    }

    private void OnNativeSystemThemeChanged(object? sender, AppThemeChangedEventArgs e)
    {
        if (AppSettings.Theme != AppThemeMode.System) return;
        _isDarkMode = e.RequestedTheme == AppTheme.Dark;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppSettings.OnSettingsChanged -= HandleSettingsChanged;
        LocalizationState.OnLanguageChanged -= HandleLanguageChanged;

        if (Application.Current != null)
        {
            Application.Current.RequestedThemeChanged -= OnNativeSystemThemeChanged;
        }
    }
}
