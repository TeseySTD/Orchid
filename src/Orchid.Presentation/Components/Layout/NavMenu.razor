@using Orchid.Application.Common.Services
@using Orchid.Application.Models
@inject IEnumerable<ICloudStorageProvider> CloudProviders
@inject ISnackbar Snackbar

<div class="d-flex flex-column h-100 w-100" style="max-width: 100%; overflow-x: hidden;">
    
    <div class="d-flex justify-center align-center py-6">
        <a href="https://github.com/TeseySTD/Orchid" target="_blank" style="line-height: 0; transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
            <Logo Color="Color.Primary" Width="56" Height="56" alt="Orchid logo"/>
        </a>
    </div>

    <MudNavMenu Class="flex-grow-1 w-100 px-2">
        <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.LibraryBooks">Library</MudNavLink>
        <MudNavLink Href="/settings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        <MudNavLink Href="https://github.com/TeseySTD/Orchid" Target="_blank" Icon="@Icons.Custom.Brands.GitHub">GitHub</MudNavLink>
    </MudNavMenu>

    <MudDivider Class="mb-4 mx-4"/>

    <div class="px-4 pb-6 w-100" style="box-sizing: border-box;">
        @if (_provider == null)
        {
            <MudText Typo="Typo.caption" Color="Color.Error" Class="px-2">No providers configured</MudText>
        }
        else if (_isAuthenticating || _isLoadingProfile)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="px-2">
                <MudSkeleton SkeletonType="SkeletonType.Circle" Width="40px" Height="40px"/>
                <MudStack Spacing="1" Class="flex-grow-1">
                    <MudSkeleton Width="70%" Height="14px"/>
                    <MudSkeleton Width="90%" Height="12px"/>
                </MudStack>
            </MudStack>
        }
        else if (_provider.IsAuthenticated && _userProfile != null)
        {
            <MudPaper Elevation="0" Class="pa-3 rounded-lg" Style="background-color: var(--mud-palette-background-grey);">
                <MudStack Spacing="2" Class="w-100">
                    <div class="d-grid w-100" style="grid-template-columns: auto minmax(0, 1fr); gap: 12px; align-items: center;">
                        <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Outlined">
                            @if (!string.IsNullOrEmpty(_userProfile.AvatarUrl))
                            {
                                <MudImage Src="@_userProfile.AvatarUrl"/>
                            }
                            else
                            {
                                @_userProfile.Name.FirstOrDefault()
                            }
                        </MudAvatar>

                        <div class="d-flex flex-column overflow-hidden">
                            <MudText Typo="Typo.body2" Class="fw-bold text-truncate" Title="@_userProfile.Name">
                                @_userProfile.Name
                            </MudText>
                            @if (!string.IsNullOrEmpty(_userProfile.Email))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="text-truncate" Title="@_userProfile.Email">
                                    @_userProfile.Email
                                </MudText>
                            }
                        </div>
                    </div>

                    <MudButton Variant="Variant.Text"
                               Color="Color.Error"
                               FullWidth="true"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Logout"
                               OnClick="HandleLogoutAsync">
                        Logout
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
        else
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="rounded-lg py-2 fw-bold"
                       StartIcon="@Icons.Material.Filled.CloudSync"
                       OnClick="HandleLoginAsync">
                Connect Cloud
            </MudButton>
        }
    </div>
</div>

@code {
    private ICloudStorageProvider? _provider;
    private CloudUserProfile? _userProfile;
    private bool _isAuthenticating;
    private bool _isLoadingProfile;

    protected override async Task OnInitializedAsync()
    {
        _provider = CloudProviders.FirstOrDefault();

        if (_provider != null)
        {
            await InitializeProviderAsync();
        }
    }

    private async Task InitializeProviderAsync()
    {
        _isLoadingProfile = true;

        var isAuthenticated = _provider!.IsAuthenticated || await _provider.TryRestoreSessionAsync();

        if (isAuthenticated)
        {
            await LoadProfileAsync();
        }
        else
        {
            _isLoadingProfile = false;
        }
    }

    private async Task HandleLoginAsync()
    {
        if (_provider == null) return;

        _isAuthenticating = true;

        try
        {
            var success = await _provider.AuthenticateAsync();
            if (success)
            {
                await LoadProfileAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Login failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAuthenticating = false;
        }
    }

    private async Task LoadProfileAsync()
    {
        if (_provider == null) return;

        _isLoadingProfile = true;
        StateHasChanged();

        try
        {
            _userProfile = await _provider.GetUserProfileAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Profile loading failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoadingProfile = false;
            StateHasChanged();
        }
    }

    private async Task HandleLogoutAsync()
    {
        if (_provider == null) return;

        try
        {
            await _provider.LogoutAsync();
            _userProfile = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Logout failed: {ex.Message}", Severity.Error);
        }
    }

}
