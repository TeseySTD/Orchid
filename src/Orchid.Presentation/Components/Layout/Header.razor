@using Orchid.Application.Common.Services
@using Orchid.Application.Models
@inject IAppSettingsService AppSettings

<MudAppBar Elevation="0" Color="Color.Transparent" Fixed="true" Dense="true">
    <MudIconButton Icon="@Icons.Material.Filled.Menu" 
                   Color="Color.Inherit" 
                   Edge="Edge.Start" 
                   OnClick="ToggleDrawer" />

    <MudSpacer />

    <MudMenu Icon="@GetCurrentThemeIcon()" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
        <MudMenuItem OnClick="@(() => SetTheme(AppThemeMode.Light))" 
                     Icon="@Icons.Material.Filled.LightMode"
                     Class="@(AppSettings.Theme == AppThemeMode.Light ? "mud-primary-text" : "")">Light</MudMenuItem>
        <MudMenuItem OnClick="@(() => SetTheme(AppThemeMode.Dark))" 
                     Icon="@Icons.Material.Filled.DarkMode"
                     Class="@(AppSettings.Theme == AppThemeMode.Dark ? "mud-primary-text" : "")">Dark</MudMenuItem>
        <MudMenuItem OnClick="@(() => SetTheme(AppThemeMode.System))" 
                     Icon="@Icons.Material.Filled.BrightnessAuto"
                     Class="@(AppSettings.Theme == AppThemeMode.System ? "mud-primary-text" : "")">System</MudMenuItem>
    </MudMenu>
</MudAppBar>

<MudDrawer @bind-Open="@_drawerOpen" Anchor="Anchor.Start" Elevation="1" Variant="@DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6" Color="Color.Primary">Orchid</MudText>
    </MudDrawerHeader>
    
    <NavMenu />
</MudDrawer>

@code {
    private bool _drawerOpen;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void SetTheme(AppThemeMode mode)
    {
        AppSettings.Theme = mode;
    }

    private string GetCurrentThemeIcon() => AppSettings.Theme switch
    {
        AppThemeMode.Light => Icons.Material.Filled.LightMode,
        AppThemeMode.Dark => Icons.Material.Filled.DarkMode,
        _ => Icons.Material.Filled.BrightnessAuto
    };
}
