@using Orchid.Application.Common.Providers
@using Orchid.Application.Dto
@inject IAppSettingsProvider AppSettings
@inject LocalizationStateService LocalizationState
@implements IDisposable

<MudAppBar Elevation="0" Color="Color.Transparent" Fixed="true" Dense="true">
    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                   Color="Color.Inherit"
                   Edge="Edge.Start"
                   OnClick="ToggleDrawer"/>

    <MudSpacer/>

    <MudMenu Icon="@Icons.Material.Filled.Translate" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight"
             TransformOrigin="Origin.TopRight" Class="mr-2">
        <MudMenuItem OnClick="@(() => SetLanguage("en-US"))"
                     Class="@(AppSettings.AppLanguage == "en-US" ? "mud-primary-text fw-bold" : "")">
            English
        </MudMenuItem>
        <MudMenuItem OnClick="@(() => SetLanguage("uk-UA"))"
                     Class="@(AppSettings.AppLanguage == "uk-UA" ? "mud-primary-text fw-bold" : "")">
            Українська
        </MudMenuItem>
    </MudMenu>

    <MudMenu Icon="@GetThemeIcon(AppSettings.Theme)" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight"
             TransformOrigin="Origin.TopRight">
        @foreach (var theme in Enum.GetValues<AppThemeMode>())
        {
            <MudMenuItem OnClick="@(() => SetTheme(theme))"
                         Icon="@GetThemeIcon(theme)"
                         Class="@(AppSettings.Theme == theme ? "mud-primary-text" : "")">
                @theme.ToString()
            </MudMenuItem>
        }
    </MudMenu>
</MudAppBar>

<MudDrawer @bind-Open="@_drawerOpen" Anchor="Anchor.Start" Elevation="1" Variant="@DrawerVariant.Temporary">
    <MudDrawerHeader>
        <MudText Typo="Typo.h6" Color="Color.Primary">Orchid</MudText>
    </MudDrawerHeader>

    <NavMenu/>
</MudDrawer>

@code {
    private bool _drawerOpen;
    
    [CascadingParameter] 
    public string CurrentLanguage { get; set; } = default!;
    
    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected override void OnInitialized()
    {
        AppSettings.OnSettingsChanged += StateHasChanged;
    }

    private void SetTheme(AppThemeMode mode)
    {
        AppSettings.Theme = mode;
    }

    private void SetLanguage(string culture)
    {
        LocalizationState.SetLanguage(culture);
    }

    private string GetThemeIcon(AppThemeMode mode) => mode switch
    {
        AppThemeMode.Light => Icons.Material.Filled.LightMode,
        AppThemeMode.Dark => Icons.Material.Filled.DarkMode,
        _ => Icons.Material.Filled.Devices
    };

    public void Dispose()
    {
        AppSettings.OnSettingsChanged -= StateHasChanged;
    }
}
