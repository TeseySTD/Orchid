@page "/book"
@using System.Collections.Concurrent
@using Orchid.Application.Common.Services
@using Orchid.Core.Models
@using Orchid.Core.Models.ValueObjects
@using Orchid.Presentation.Services
@inject IBookResourcesService BookResourcesService
@inject BookPaginationService BookPaginationService
@inject NavigationManager NavManager
@inject IJSRuntime Js
@implements IAsyncDisposable

<MudDrawer @bind-Open="@_drawerOpen" Anchor="Anchor.End" Elevation="2" Variant="DrawerVariant.Temporary" Width="320px">
    <BookInfo
        Book="@_currentBook"
        Cover="@_currentBookCover"
        CurrentChapterTitle="@_chapters.ElementAtOrDefault(_currentPageIdentifier.ChapterIndex)?.Title"
        TotalBookPages="@_chaptersPages.Sum(kv => kv.Value.Length)"
        CurrentChapterPageIndex="@_currentPageIdentifier.ChapterIndex"
        CurrentChapterTotalPages="@(_chaptersPages.GetValueOrDefault(_currentPageIdentifier.ChapterIndex)?.Length ?? 0)"

    />
</MudDrawer>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-0" Style="height: 100%; display: flex; flex-direction: column;">
    <LoadingOverlay IsVisible="_isBookLoading" Text="Loading book..."/>

    @if (_currentBook != null)
    {
        <FloatingInfoButton OnClick="() => _drawerOpen = !_drawerOpen"/>

        <Reader @ref="_reader"
                BookId="@_currentBook.Id"
                Chapters="@_chapters"
                ChaptersPages="@_chaptersPages"
                Css="@_css"
                OnPageChanged="@(id => _currentPageIdentifier = id)"
                OnPageContextChangeCallback="OnPageContextChange"
                OnPageContextChangeEndCallback="OnPageContextChangeEnd"/>
    }
</MudContainer>

@code {

    [SupplyParameterFromQuery(Name = "path")]
    public string? FilePath { get; set; }

    private Reader _reader = null!;
    private Book? _currentBook;
    private Cover _currentBookCover = null!;
    private IEnumerable<CssFile> _css = [];
    private List<Chapter> _chapters = [];
    private readonly ConcurrentDictionary<int, PageData[]> _chaptersPages = new();

    private PageIdentifier _currentPageIdentifier = PageIdentifier.Empty;
    private bool _isBookLoading;
    private bool _drawerOpen;

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(FilePath))
        {
            await ReadBook(System.Net.WebUtility.UrlDecode(FilePath));
        }
        else
        {
            NavManager.NavigateTo("/");
        }
    }

    private async Task ReadBook(string path)
    {
        _isBookLoading = true;
        StateHasChanged();

        try
        {
            _currentBook = await BookResourcesService.ReadBookAsync(path);
            _css = await BookResourcesService.GetBookCssFilesAsync(path);
            _chapters = await BookResourcesService.ReadChaptersAsync(path);
            _currentBookCover = _currentBook.Cover ?? await DefaultCover();

            StateHasChanged();
            await Task.Delay(50);

            StartPagesCalculation();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            NavManager.NavigateTo("/");
        }
    }

    private async Task<Cover> DefaultCover()
    {
        await using var stream = await FileSystem.OpenAppPackageFileAsync("wwwroot/images/no_cover_image.png");
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return Cover.Create("no_cover_image.png", "images/no_cover_image.png", ms.ToArray())!;
    }

    private async Task OnPageContextChange()
    {
        _isBookLoading = true;
        await InvokeAsync(StateHasChanged);
    }

    private void OnPageContextChangeEnd()
    {
        StartPagesCalculation();
    }

    private void StartPagesCalculation()
    {
        BookPaginationService.StartBackgroundPageCalculation(
            _currentBook!.Id, _chapters, _reader.PaginationSandbox,
            async (idx, pages) =>
            {
                _chaptersPages[idx] = pages;
                await InvokeAsync(() => _reader.Update());
            },
            async () =>
            {
                _isBookLoading = false; // When all pages calculated - remove loader
                await InvokeAsync(() =>
                {
                    _reader.RestorePosition(_currentPageIdentifier);
                    StateHasChanged();
                });
            },
            jsRuntime: Js
        );
    }

    public async ValueTask DisposeAsync()
    {
        BookPaginationService.StopCalculation();
        try
        {
            if (_reader.PaginationSandbox.Context != null)
            {
                await Js.InvokeVoidAsync("utils.cleanupElementContent", _reader.PaginationSandbox);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Cleanup failed: {ex.Message}");
        }

        _chapters.Clear();
        _chapters = null!;
        _chaptersPages.Clear();
        _currentBook = null;

        GC.Collect(2, GCCollectionMode.Forced, true);
        GC.WaitForPendingFinalizers();
    }

}
