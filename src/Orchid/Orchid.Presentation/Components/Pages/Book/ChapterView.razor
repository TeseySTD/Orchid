@using Orchid.Core.Models.ValueObjects
@inject IJSRuntime Js
@implements IAsyncDisposable

<style>
    @((MarkupString)BookCssAsString)
</style>

<div class="chapter-viewport" @ref="_chapterViewportElement">
    @*Pagination sandbox*@
    <div @ref="PaginationSandbox"
         id="paginationSandbox"
         class="chapter-content">
    </div>
    
    @for (int i = 0; i < 3; i++)
    {
        var slotIndex = i;
        <div @key="@($"slot-{slotIndex}")"
             @ref="_slotRefs[slotIndex]"
             class="@GetSlotClass(slotIndex)">
            @if (!string.IsNullOrEmpty(_slotContents[slotIndex]))
            {
                @* ReSharper disable once NullableWarningSuppressionIsUsed *@
                @((MarkupString)_slotContents[slotIndex]!)
            }
        </div>
    }
</div>

@code {
    [Parameter] public string? PreviousPageHtml { get; set; }
    [Parameter] public string? CurrentPageHtml { get; set; }
    [Parameter] public string? NextPageHtml { get; set; }
    [Parameter] public IEnumerable<CssFile> BookCss { get; set; } = [];
    
    [Parameter] public EventCallback OnPageContextChangeCallback { get; set; }

    private string?[] _slotContents = new string?[3];
    private ElementReference[] _slotRefs = new ElementReference[3];
    private int _activeSlotIndex = 0;
    
    public ElementReference ChapterElement => _slotRefs[_activeSlotIndex];
    public ElementReference PaginationSandbox;
    private ElementReference _chapterViewportElement;
    private string BookCssAsString => string.Join("\n", BookCss.Select(d => d.Content));
    private DotNetObjectReference<ChapterView>? _dotNetRef;

    protected override void OnParametersSet()
    {
        UpdateSlots();
    }

    private void UpdateSlots()
    {
        int newActiveIndex = -1;
        for (int i = 0; i < 3; i++)
        {
            if (_slotContents[i] == CurrentPageHtml && !string.IsNullOrEmpty(CurrentPageHtml))
            {
                newActiveIndex = i;
                break;
            }
        }

        // Drop slots if not found page 
        if (newActiveIndex == -1)
        {
            _activeSlotIndex = 0;
            _slotContents[0] = CurrentPageHtml;
            _slotContents[1] = NextPageHtml;
            _slotContents[2] = PreviousPageHtml;
        }
        else
        {
            _activeSlotIndex = newActiveIndex;
            
            int nextIdx = (_activeSlotIndex + 1) % 3;
            int prevIdx = (_activeSlotIndex + 2) % 3;
            
            _slotContents[nextIdx] = NextPageHtml;
            _slotContents[prevIdx] = PreviousPageHtml;
        }
    }

    private string GetSlotClass(int index)
    {
        if (index == _activeSlotIndex) return "chapter-content active-page";
        
        if (index == (_activeSlotIndex + 1) % 3) return "page-buffer next-page";
        return "page-buffer prev-page";
    }

    public async Task<int> GoToPageLocatorAsync(string locator)
    {
        try
        {
            return await Js.InvokeAsync<int>("orchidReader.scrollToLocator", ChapterElement, locator);
        }
        catch
        {
            return 0;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("utils.pageContextObserve", _chapterViewportElement, _dotNetRef);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef != null)
        {
            try { await Js.InvokeVoidAsync("utils.pageContextUnobserve", _chapterViewportElement); }
            catch (JSDisconnectedException) { }
            finally { _dotNetRef.Dispose(); }
        }
    }
}
